  constructor() {

    this.timeTrackingForm = this.fb.group({

      ticketTaskNumber: ['', Validators.required],

      Datefrom: ['', Validators.required],

      Dateto: ['', Validators.required],

      userName: ['', Validators.required],

      startTime: ['', Validators.required],

