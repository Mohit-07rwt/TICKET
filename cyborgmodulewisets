  }[] = [];

 registerTimeCalculation() {

    this.timeTrackingForm
      .get('startTime')
      ?.valueChanges
      .subscribe(() => {
        this.calculateHours();
      });

    this.timeTrackingForm
      .get('endTime')
      ?.valueChanges
      .subscribe(() => {
        this.calculateHours();
      });
  }

  calculateHours() {

    const start =
      this.timeTrackingForm.get('startTime')?.value;

    const end =
      this.timeTrackingForm.get('endTime')?.value;

    if (!start || !end) {
      return;
    }

    const startDate =
      new Date(`2000-01-01T${start}`);

    const endDate =
      new Date(`2000-01-01T${end}`);

    const difference =
      (endDate.getTime() -
        startDate.getTime()) /
      (1000 * 60 * 60);

    this.timeTrackingForm.patchValue(
      {
        totalHours:
          difference > 0
            ? Number(difference.toFixed(2))
            : 0
      },
      {
        emitEvent: false
      }
    );
  }



  resetForm() {

    this.timeTrackingForm.reset({

      ticketTaskNumber: '',

      workDate: null,

      userName: '',

      startTime: '',

      endTime: '',

      totalHours: 0,

      workDescription: '',

      billingType: 0
    });

    this.getDate();
  }


  getDate() {
    this.commonService.show();

    this.ticketService.Get_ServerDate().subscribe({
      next: (rows: any[]) => {

        if (!rows || !rows.length) {
          this.commonService.hide();
          this.dialogService.openAlert('Alert', 'Failed to load server date.');
          return;
        }

        this.commonService.show();

        const serverDateStr = rows[0].ServerDate;
        this.mindate = this.convertToDate(rows[0].mindate);
        this.maxdate = this.convertToDate(rows[0].maxdate);

        const [day, month, year] = serverDateStr.split('/').map(Number);
        this.serverDate = new Date(year, month - 1, day);
        // Datepicker binds to a Date; submit() converts back to yyyy-MM-dd.
        this.timeTrackingForm.patchValue({
          Dateto: this.serverDate,
          Datefrom: this.serverDate
        });

        this.commonService.hide();

      },
      error: err => {
        this.commonService.hide();
        console.error(err);
      }
    });
  }


  convertToDate(dateStr: string): Date | null {
    if (!dateStr) return null;

    const parts = dateStr.split('/');
    return new Date(
      Number(parts[2]),       // year
      Number(parts[1]) - 1,   // month
      Number(parts[0])        // day
    );
  }

  convertToApiDate(date: any) {
    const d = new Date(date);
    const month = ('0' + (d.getMonth() + 1)).slice(-2);
    const day = ('0' + d.getDate()).slice(-2);
    return `${d.getFullYear()}-${month}-${day}`;
  }



  loadModuleWiseReport() {

    const from = this.convertToApiDate(
      this.timeTrackingForm.get('Datefrom')?.value
    );

    const to = this.convertToApiDate(
      this.timeTrackingForm.get('Dateto')?.value
    );

    const moduleId = Number(
      this.timeTrackingForm.get('module')?.value
    );

    this.commonService.show();

    this.ticketReportService
      .getModuleWiseReport(from, to, moduleId)
      .subscribe({

        next: (res: any) => {

          this.commonService.hide();

          this.rowData = Array.isArray(res) ? res : [];

          if (this.rowData.length > 0) {

            const firstRow = this.rowData[0];

            const hiddenFields: string[] = [
              'TID',
              'DeletedDate',
              'InsertedBy',
              'InsertedDate',
              'UpdatedBy',
              'UpdatedDate',
              'Assigned To',
              'Assigned Team',
              'Assigned Date',
              'Target Date',
              'Assignment Remarks'
            ];

            this.columnDefs = Object.keys(firstRow).map((key) => ({
              headerName: this.formatHeader(key),
              field: key,
              sortable: true,
              filter: true,
              resizable: true,
              hide: hiddenFields.includes(key)
            }));

          } else {
            this.columnDefs = [];
          }

        },

        error: (err: any) => {

          this.commonService.hide();

          this.rowData = [];
          this.columnDefs = [];

        }

      });

  }

  // Optional: readable header format
  formatHeader(key: string): string {
    return key
      .replace(/([A-Z])/g, ' $1')
      .replace(/_/g, ' ')
      .replace(/^./, (str) => str.toUpperCase());
  }



