/* Empty state for the report grid (shown before a run / when no rows) */
.report-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  min-height: 280px;
  padding: 40px 16px;
  text-align: center;
  color: var(--text-muted);
}
.report-empty i {
  font-size: 42px;
  opacity: 0.6;
}
.report-empty p {
  margin: 0;
  font-size: 14.5px;
}
.report-empty strong {
  color: var(--text);
}
