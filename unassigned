      next: (res: any) => {

        this.rowData = Array.isArray(res) ? res : [res];

        const hiddenFields: string[] = [

          'TID',
          'DeletedDate',
          'Extension',
          'IsActive',
          'InsertedBy',
          'InsertedDate',
          'UpdatedBy',
          'UpdatedDate',
          'DeletedBy'

        ];

        if (res.error === true) {

          this.CommonService.hide();

          this.dialogService.openAlert(
            'Alert',
            res.Msg
          );

          return;

        }

        if (this.rowData.length > 0) {

          this.columnDefs = Object.keys(this.rowData[0]).map(key => ({

            field: key,

            headerName: key,

            sortable: true,

            filter: true,

            resizable: true,

            width: 180,

            hide: hiddenFields.includes(key)

          }));


          //// View Button

          //this.columnDefs.unshift({

